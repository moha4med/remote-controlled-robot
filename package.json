{
  "name": "remote-controlled-robot",
  "private": true,
  "devDependencies": {
    "tailwindcss": "^3.4.1"
  },
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i app/static/style/tailwind.css -o app/static/style/tailwind.output.css",
    "watch:css": "tailwindcss -c tailwind.config.js -i app/static/style/tailwind.css -o app/static/style/tailwind.output.css --watch"
  }
}
